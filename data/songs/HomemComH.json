n class=\"chord\" data-chord=\"Em\">Em</span>     <span class=\"chord\" data-chord=\"A7\">A7</span>             <span class=\"chord\" data-chord=\"D\">D</span>\n<span class=\"lyric-line\">Ah! Mamãe, aqui estou eu</span>\n   <span class=\"chord\" data-chord=\"G\">G</span>              <span class=\"chord\" data-chord=\"C#m7(5-)\">C#m7(5-)</span>\n<span class=\"lyric-line\">Mamãe, aqui estou eu</span>\n     <span class=\"chord\" data-chord=\"F#7\">F#7</span>      <span class=\"chord\" data-chord=\"Bm\">Bm</span>\n<span class=\"lyric-line\">Sou homem com H</span>\n           <span class=\"chord\" data-chord=\"F#7\">F#7</span>\n<span class=\"lyric-line\">E como sou</span>\n\n<span class=\"lyric-line\">[Refrão 2]</span>\n\n                    <span class=\"chord\" data-chord=\"Bm\">Bm</span>\n<span class=\"lyric-line\">Nunca vi rastro de cobra</span>\n                  <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Nem couro de lobisomem</span>\n\n<span class=\"lyric-line\">Se correr, o bicho pega</span>\n                   <span class=\"chord\" data-chord=\"Bm\">Bm</span>\n<span class=\"lyric-line\">Se ficar, o bicho come</span>\n                 <span class=\"chord\" data-chord=\"Bm/A\">Bm/A</span>\n<span class=\"lyric-line\">Porque eu sou é home</span>\n                 <span class=\"chord\" data-chord=\"Abº\">Abº</span>\n<span class=\"lyric-line\">Porque eu sou é home</span>\n                  <span class=\"chord\" data-chord=\"F#7\">F#7</span>\n<span class=\"lyric-line\">Menino, eu sou é home</span>\n                  <span class=\"chord\" data-chord=\"Bm\">Bm</span>            \n<span class=\"lyric-line\">Menino, eu sou é home</span>\n         <span class=\"chord\" data-chord=\"F#7\">F#7</span>  <span class=\"chord\" data-chord=\"Bm\">Bm</span>\n<span class=\"lyric-line\">Como sou</span>\n\n <span class=\"chord\" data-chord=\"Bm\">Bm</span>     <span class=\"chord\" data-chord=\"Em\">Em</span>     <span class=\"chord\" data-chord=\"F#