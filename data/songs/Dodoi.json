{
    "title": "Dodói",
    "artist": "Luiz Tatit",
    "composer": "Luiz Tatit / Itamar Assumpcao",
    "lyricsHtml": "\n[Intro] <span class=\"chord\" data-chord=\"Am\">Am</span>  <span class=\"chord\" data-chord=\"Em\">Em</span>  <span class=\"chord\" data-chord=\"C7M\">C7M</span>  <span class=\"chord\" data-chord=\"Em\">Em</span>\n        <span class=\"chord\" data-chord=\"Am\">Am</span>  <span class=\"chord\" data-chord=\"G6\">G6</span>  <span class=\"chord\" data-chord=\"C7M\">C7M</span>  <span class=\"chord\" data-chord=\"B7\">B7</span>\n\n   <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Eu ando tão dodói</span>\n<span class=\"lyric-line\">Mas tão dodói</span>\n           <span class=\"chord\" data-chord=\"B7\">B7</span>\n<span class=\"lyric-line\">Que quando ando dói</span>\n<span class=\"lyric-line\">Quando não ando dói</span>\n    <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Meu corpo todo dói</span>\n   <span class=\"chord\" data-chord=\"C7M\">C7M</span>\n<span class=\"lyric-line\">Tendão dói</span>\n  <span class=\"chord\" data-chord=\"C#º\">C#º</span>\n<span class=\"lyric-line\">Dedão dói</span>\n  <span class=\"chord\" data-chord=\"G6/D\">G6/D</span>\n<span class=\"lyric-line\">Pomo-de-adão dói</span>\n  <span class=\"chord\" data-chord=\"B7\">B7</span>\n<span class=\"lyric-line\">Ouvido dói</span>\n<span class=\"lyric-line\">Libido dói</span>\n<span class=\"chord\" data-chord=\"Cº\">Cº</span>\n<span class=\"lyric-line\">Fígado dói</span>\n <span class=\"chord\" data-chord=\"G6/B\">G6/B</span>\n<span class=\"lyric-line\">Até meu dom dói</span>\n     <span class=\"chord\" data-chord=\"B7\">B7</span>\n<span class=\"lyric-line\">Pois quando canto</span>\n<span class=\"lyric-line\">Não importa o tom dói</span>\n\n( <span class=\"chord\" data-chord=\"Em\">Em</span>  <span class=\"chord\" data-chord=\"C7M\">C7M</span>  <span class=\"chord\" data-chord=\"B7\">B7</span>  <span class=\"chord\" data-chord=\"G6/B\">G6/B</span>  <span class=\"chord\" data-chord=\"B7\">B7</span> )\n",
