    "lyricsHtml": "\n[Intro] <span class=\"chord\" data-chord=\"E7\">E7</span>  <span class=\"chord\" data-chord=\"Am\">Am</span>  <span class=\"chord\" data-chord=\"Em\">Em</span>  <span class=\"chord\" data-chord=\"B7\">B7</span>\n\n<span class=\"lyric-line\">[Primeira Parte]</span>\n\n<span class=\"chord\" data-chord=\"Em\">Em</span>                       <span class=\"chord\" data-chord=\"Am\">Am</span>\n<span class=\"lyric-line\">   A todo mundo eu dou psiu</span>\n                     <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Perguntando por meu bem</span>\n                    <span class=\"chord\" data-chord=\"F#m7(5-)\">F#m7(5-)</span>\n<span class=\"lyric-line\">Tendo um coração vazio</span>\n                   <span class=\"chord\" data-chord=\"B7\">B7</span>\n<span class=\"lyric-line\">Vivo assim a dar psiu</span>\n                 <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Sabiá vem cá também</span>\n\n                      <span class=\"chord\" data-chord=\"Am\">Am</span>\n<span class=\"lyric-line\">A todo mundo eu dou psiu</span>\n                 <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Perguntando por meu bem</span>\n                    <span class=\"chord\" data-chord=\"F#m7(5-)\">F#m7(5-)</span>\n<span class=\"lyric-line\">Tendo um coração vazio</span>\n                   <span class=\"chord\" data-chord=\"B7\">B7</span>\n<span class=\"lyric-line\">Vivo assim a dar psiu</span>\n              <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Sabiá vem cá também</span>\n\n<span class=\"lyric-line\">[Refrão]</span>\n\n                   <span class=\"chord\" data-chord=\"E7\">E7</span>\n<span class=\"lyric-line\">Tú que andas pelo mundo (Sabiá)</span>\n                 <span class=\"chord\" data-chord=\"Am\">Am</span>\n<span class=\"lyric-line\">Tú que tanto já voou (Sabiá)</span>\n                    <span class=\"chord\" data-chord=\"D7\">D7</span>\n<span class=\"lyric-line\">Tú que cantas passarinhos (Sabiá)</span>\n                <span class=\"chord\" data-chord=\"G\">G</span>\n<span class=\"lyric-line\">Alivia a minha dor</span>\n\n<span class=\"lyric-line\">[Ponte]</span>\n\n <span class=\"chord\" data-chord=\"C7\">C7</span>        <span class=\"chord\" data-chord=\"B7\">B7</span>      <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Tem pena d'eu (Sabiá)</span>\n           <span class=\"chord\" data-chord=\"B7\">B7</span>      <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Diz por favor (Sabiá)</span>\n                      <span class=\"chord\" data-chord=\"B7\">B7</span>        <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Tu que tanto anda no mundo (Sabiá)</span>\n              <span class=\"chord\" data-chord=\"B7\">B7</span>        <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Onde anda meu amor (Sabiá)</span>\n\n <span class=\"chord\" data-chord=\"C7\">C7</span>        <span class=\"chord\" data-chord=\"B7\">B7</span>      <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Tem pena d'eu (Sabiá)</span>\n         <span class=\"chord\" data-chord=\"B7\">B7</span>        <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Diz por favor (Sabiá)</span>\n                <span class=\"chord\" data-chord=\"B7\">B7</span>              <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Tu que tanto anda no mundo (Sabiá)</span>\n                <span class=\"chord\" data-chord=\"B7\">B7</span>\n<span class=\"lyric-line\">Alivia a minha dor</span>\n    <span class=\"chord\" data-chord=\"C7\">C7</span>  <span class=\"chord\" data-chord=\"B7\">B7</span>  <span class=\"chord\" data-chord=\"Em\">Em</span>\n<span class=\"lyric-line\">Sabiá</span>\n\n<span class=\"lyric-line\">[Prime